def validate_session(token):
    sessions = load_json(SESSIONS_FILE, [])
    now = datetime.now(timezone.utc)
    for s in sessions:
        if s.get("token") == token:
            try:
                expires = datetime.fromisoformat(s.get("expires_at", "")).replace(tzinfo=timezone.utc)
                if now > expires:
                    return None
            except:
                return None
            return s
    return None


